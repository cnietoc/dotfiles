#!/usr/bin/env bash

set -euo pipefail

source "$DOTLY_PATH/scripts/core/_main.sh"
source "$DOTFILES_PATH/shell/functions.sh"

##? Login to atuin sync using credentials from Bitwarden and sync history.
##? Run this once on each new machine after installing atuin.
##?
##? Usage:
##?   setup
docs::parse "$@"

load_secrets atuin

echo "Logging into atuin as $ATUIN_USERNAME..."
atuin login -u "$ATUIN_USERNAME" -p "$ATUIN_PASSWORD"

echo "Syncing history..."
atuin sync

echo "Done. Run 'atuin import zsh' if this is the first machine."
